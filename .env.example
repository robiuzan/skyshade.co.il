# ── Sky Shade (סקיי שייד) environment template ─────────────────────────────
# Copy to `.env.local` and fill real values. Never commit `.env.local`.
# Values marked 🔶 are assumptions — confirm with client.

# Public site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL="https://skyshade.co.il"

# Business contact (also mirrored in lib/site-config.ts)
NEXT_PUBLIC_PHONE="050-5063152"
NEXT_PUBLIC_WHATSAPP="972505063152"          # own number (phoneOverride)

# Analytics & tracking — leave blank to disable
NEXT_PUBLIC_GA_ID=""                          # 🔶 GA4 Measurement ID (G-XXXXXXXXXX)

# Lead routing — server-side only
LEAD_EMAIL_TO="yossi@skyshade.co.il"          # 🔶 confirm send-to address
# SMTP / email provider credentials (added when the contact form is wired up)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
